{
  "name": "social-media-calendar",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:artifact": "ARTIFACT=1 vite build && cp dist/index.html artifact.html",
    "preview": "vite preview",
